# Environment Configuration for ScriptED Backend

# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=ScriptED Backend
VERSION=1.0.0

# CORS - Add your frontend URL
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Model Configuration
SPACY_MODEL=en_core_web_sm
MINILM_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Text Enhancement Model (for dialogue and screenplay structure)
TEXT_MODEL=llama3.2:latest

# Vision Model (for image analysis and visual context)
VISION_MODEL=minicpm-v:latest

USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434

# GPU Configuration
USE_GPU=true
GPU_MEMORY_FRACTION=0.85
LOAD_IN_4BIT=true

# Context Storage
CONTEXT_STORAGE_PATH=./context_store
CONTEXT_TTL_HOURS=24
MAX_CONTEXT_SIZE_MB=100

# Redis (Optional - for production)
# REDIS_URL=redis://localhost:6379
# USE_REDIS=false

# Processing Configuration
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_SECONDS=600
